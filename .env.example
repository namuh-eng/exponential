# =============================================================================
# exponential — Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres)
# Either set DATABASE_URL directly, or set individual DB_* vars and the app
# will construct the connection string automatically.
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:password@localhost:5432/exponential
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=exponential
# DB_SSL=true  # Uncomment for remote/production databases

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Auth (Better Auth)
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google OAuth (optional — required for "Continue with Google")
# Get credentials at https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# AWS — S3 (file uploads), SES (emails)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
S3_BUCKET=
SENDER_EMAIL=

# -----------------------------------------------------------------------------
# Docker Compose (dev override ports — only needed if defaults conflict)
# -----------------------------------------------------------------------------
# PG_PORT=5433       # Host port for Postgres (default: 5432)
# REDIS_PORT=6380    # Host port for Redis (default: 6379)

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
# TEST_ACCOUNT_EMAIL=test@example.com  # Used by Playwright auth setup

# -----------------------------------------------------------------------------
# AWS ECS deployment (generated by scripts/prepare-ecs-deploy-env.sh and
# scripts/preflight.sh; .env is intentionally gitignored)
# -----------------------------------------------------------------------------
# APP_NAME=exponential
# AWS_ACCOUNT_ID=
# PUBLIC_BASE_URL=http://<alb-dns-or-custom-domain>
# KRATOS_PUBLIC_URL=${PUBLIC_BASE_URL}/auth
# PRIVATE_DNS_ZONE=exponential.internal
# PRIVATE_DNS_ZONE_ID=
# KRATOS_INTERNAL_URL=http://kratos.${PRIVATE_DNS_ZONE}:4433
# ECS_EXECUTION_ROLE_ARN=
# ECS_TASK_ROLE_ARN=
# DATABASE_URL_SECRET_ARN=
# REDIS_URL_SECRET_ARN=
# KRATOS_DSN_SECRET_ARN=
# KRATOS_COOKIE_SECRET_ARN=
# GOOGLE_CLIENT_ID_SECRET_ARN=
# GOOGLE_CLIENT_SECRET_SECRET_ARN=
# PRIV_SUBNET_A=
# PRIV_SUBNET_B=
# APP_SG=
# API_TG_ARN=
# WEB_TG_ARN=
# KRATOS_TG_ARN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
