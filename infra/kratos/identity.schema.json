{
  "$id": "https://exponential.local/identity.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exponential Identity",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "ory.sh/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              }
            },
            "verification": {
              "via": "email"
            },
            "recovery": {
              "via": "email"
            }
          }
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["email"],
      "additionalProperties": true
    }
  }
}
